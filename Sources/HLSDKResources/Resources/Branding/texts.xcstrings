        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estás seguro de que quieres continuar? Su cuenta y sus datos personales serán borrados. Esto no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
