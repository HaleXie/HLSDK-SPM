    "CustomerInstructionsMsg" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie diese App, um einen Anruf entgegenzunehmen. Sie müssen sich nicht anmelden – wenden Sie sich bitte an Ihren Vertreter, um einen Einladungslink zu erhalten und loszulegen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use this app to receive a call. No need to log in - please contact your representative to receive an invitation link to get started."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilice esta aplicación para recibir una llamada. No es necesario iniciar sesión; comuníquese con su representante para recibir un enlace de invitación para comenzar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez cette application pour recevoir un appel. Pas besoin de vous connecter - veuillez contacter votre représentant pour recevoir un lien d'invitation pour commencer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilizza questa app per ricevere una chiamata. Non è necessario effettuare l'accesso: contatta il tuo rappresentante per ricevere un collegamento di invito per iniziare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "電話を受けるにはこのアプリを使用します。ログインする必要はありません。開始するには、担当者に連絡して招待リンクを受け取ってください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 앱을 사용하여 전화를 받으세요. 로그인할 필요가 없습니다. 담당자에게 문의하여 시작하려면 초대 링크를 받으세요."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use este aplicativo para receber uma chamada. Não há necessidade de fazer login – entre em contato com seu representante para receber um link de convite para começar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用此应用程序接听电话。无需登录 - 请联系您的代表以接收邀请链接开始使用。"
          }
        }
      }
    },
