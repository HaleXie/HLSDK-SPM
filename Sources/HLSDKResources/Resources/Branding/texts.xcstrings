      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ultra-Low-Bandwidth-Modus. Bitten Sie andere, Inhalte zu teilen. Oder Sie können über das Menü unten teilen."
