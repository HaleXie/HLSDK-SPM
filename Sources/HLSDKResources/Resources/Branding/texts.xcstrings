    "permsExplanationAlertMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}} sind die Berechtigungen \\\"Kamera\\\" und \\\"Mikrofon\\\" erforderlich, um Videoanrufe zu ermöglichen. Bitte erlauben Sie diesen Berechtigungen, die App zu nutzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}} requires the Camera and Microphone permissions to make video calling possible. Please allow these permissions to use the app."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}} requiere los permisos de cámara y micrófono para poder hacer  videollamadas. Conceda estos permisos para usar la aplicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}} nécessite les autorisations Appareil photo et Microphone pour rendre les appels vidéo possibles. Veuillez valider l'autorisation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}} richiede le autorizzazioni per fotocamera e microfono per rendere possibili le videochiamate. Consenti a queste autorizzazioni di utilizzare l'app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}}は、ビデオ通話を可能にするためにカメラとマイクの権限が必要です。これらの権限でアプリを使用できるようにしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}} 이 화상 통화를하려면 카메라 및 마이크 권한이 필요합니다. 앱을 사용하도록 허용하십시오."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}} requer as permissões de câmera e microfone para possibilitar a videochamada. Por favor, aceite essas permissões para usar o aplicativo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}}软件需要获得设备摄像头及麦克风的权限来进行视频通话,请授权."
          }
        }
      }
    },
