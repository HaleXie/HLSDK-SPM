    "Tutorial3Message1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Anrufe beginnen im Face-to-Face-Modus, ähnlich wie bei anderen Videoanrufanwendungen. Drehen Sie Ihr Gerät so, dass es im Querformat angezeigt wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All calls begin in Face to Face mode similar to other video call applications. Turn your device to display in landscape."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todas las llamadas comienzan en el modo Cara a Cara similar a otras aplicaciones de videollamadas. Gire su dispositivo para que se muestre en horizontal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tous les appels commencent en mode Face à Face, comme les autres applications d'appel vidéo. Tournez votre appareil pour afficher en paysage."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutte le chiamate iniziano in modalità Face to Face simile ad altre applicazioni di videochiamata. Trasforma il tuo dispositivo per visualizzare in orizzontale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての通話は、他のビデオ通話アプリケーションと同様に対面モードで開始されます。デバイスを回転させて横向きに表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 통화는 다른 화상 통화 애플리케이션과 유사한 Face to Face 모드에서 시작됩니다. 기기를 돌려 가로로 표시하세요."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todas as chamadas começam no modo Face a Face semelhante a outros aplicativos de chamada de vídeo. Vire seu dispositivo para exibir em modo paisagem."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "与其他视频通话应用程序类似，所有通话均以面对面模式开始。旋转设备以横向显示。"
          }
        }
      }
    },
    "Tutorial3Message2" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählen Sie Ihre Rolle aus dem Menü aus, um auszuwählen, ob Sie Hilfe geben oder erhalten möchten. Dadurch wird der Merged-Reality-Modus gestartet, in dem die beiden Videostreams miteinander kombiniert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Select your Role from the menu to choose whether you will Give or Receive Help. This will launch merged reality mode blending the two video streams together."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seleccione su rol en el menú para elegir si dará o recibirá ayuda. Esto lanzará el modo de realidad fusionada combinando las dos secuencias de video."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sélectionnez votre rôle dans le menu pour choisir si vous allez donner ou recevoir de l'aide. Cela lancera le mode de réalité fusionnée combinant les deux flux vidéo ensemble."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seleziona il tuo ruolo dal menu per scegliere se dare o ricevere aiuto. Questo avvierà la modalità di realtà unita che fonde insieme i due flussi video."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メニューから役割を選択して、ヘルプするか・ヘルプされるかを選択します。これにより、2つのビデオストリームをミックスするマージリアリティモードが起動します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메뉴에서 역할을 선택하여 도움을 줄 것인지받을 것인지 선택하십시오. 이렇게하면 두 비디오 스트림을 함께 혼합하는 병합 현실 모드가 시작됩니다."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecione sua função no menu para escolher se você irá oferecer ou receber ajuda. Isso iniciará o modo de realidade mista, combinando os dois fluxos de vídeo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从菜单中选择您的角色，以选择是给予还是接受帮助。这将启动将两个视频流融合在一起的合并现实模式。"
          }
        }
      }
    },
