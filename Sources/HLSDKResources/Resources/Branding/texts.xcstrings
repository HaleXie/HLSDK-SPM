          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Está seguro de que desea abandonar este hilo de ayuda? La única forma de volver a este cuadro de trabajo será haciendo clic en el vínculo que utilizó para acceder originalmente."
