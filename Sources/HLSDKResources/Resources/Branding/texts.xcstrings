    "LeaveWorkboxMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchten Sie diesen Hilfe-Thread wirklich verlassen? Sie können nur dann zu dieser Workbox zurückkehren, wenn Sie auf den Link klicken, über den Sie ursprünglich darauf zugegriffen haben."
