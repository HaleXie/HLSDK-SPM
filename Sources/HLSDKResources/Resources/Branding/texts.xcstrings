      }
    },
    "EnableAudioWarning" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Aktivieren der Audiofunktion während einer aktiven Telefonverbindung kann die Videoverbindung dieses Anrufs beeinträchtigen. Stellen Sie sicher, dass Sie mit niemandem in diesem Anruf telefonieren, bevor Sie die Audiofunktion aktivieren!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enabling audio while you have an active phone call connection can interfere with the video connection of this call. Make sure you aren’t on a phone call with anyone on this call before enabling audio!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si habilita el audio mientras tiene una llamada telefónica activa, puede interferir con la conexión de video de esta llamada. ¡Asegúrese de no estar en una llamada telefónica con nadie en esta llamada antes de habilitar el audio!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'activation de l'audio alors que vous avez une connexion téléphonique active peut interférer avec la connexion vidéo de cet appel. Assurez-vous que vous n'êtes pas en communication téléphonique avec quelqu'un de cet appel avant d'activer l'audio !"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abilitare l'audio mentre hai una connessione telefonica attiva può interferire con la connessione video di questa chiamata. Assicurati di non essere impegnato in una chiamata telefonica con nessuno in questa chiamata prima di abilitare l'audio!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "電話通話接続中にオーディオを有効にすると、この通話のビデオ接続が妨げられる可能性があります。オーディオを有効にする前に、この通話で誰かと通話していないことを確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성 전화 통화 연결이 있는 동안 오디오를 활성화하면 이 통화의 비디오 연결을 방해할 수 있습니다. 오디오를 활성화하기 전에 이 통화에 참여하는 사람과 전화 통화를 하지 않았는지 확인하세요!"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilitar o áudio enquanto você tem uma conexão de chamada telefônica ativa pode interferir na conexão de vídeo desta chamada. Certifique-se de que você não esteja em uma chamada telefônica com ninguém nesta chamada antes de habilitar o áudio!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在通话过程中启用音频可能会干扰此通话的视频连接。在启用音频之前，请确保您没有与此通话中的任何人通话！"
          }
        }
      }
    },
