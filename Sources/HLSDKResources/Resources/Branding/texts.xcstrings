    "DisableCameraMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie den Zugriff auf Ihre Kamera deaktivieren, können Sie in unserer App keine Hilfe geben oder empfangen. Bitte aktivieren Sie den Zugriff auf Ihre Kamera in den Datenschutzeinstellungen des Geräts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By disabling access to your camera, you will not be able to give or receive help inside our app. Please enable access to your camera in device's privacy settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al deshabilitar el acceso a su cámara, no podrá dar ni recibir ayuda dentro de nuestra aplicación. Habilite el acceso a su cámara en la configuración de privacidad del dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En désactivant l'accès à votre caméra, vous ne pourrez ni donner ni recevoir d'aide dans notre application. Veuillez autoriser l'accès à votre caméra dans les paramètres de confidentialité de l'appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disabilitando l'accesso alla tua fotocamera, non sarai in grado di dare o ricevere aiuto all'interno della nostra app. Abilitare l'accesso alla videocamera nelle impostazioni sulla privacy del dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カメラアクセスを無効化すると、Help Lightning アプリ内ヘルプの提供・受領ができなくなります。端末のプライバシー設定でカメラアクセスを許可してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "카메라에 대한 액세스를 비활성화하면 앱 내에서 도움말을 제공하거나받을 수 없습니다. 장치의 개인 정보 설정에서 카메라에 액세스 할 수있게하십시오."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao desativar o acesso à sua câmera, você não poderá dar ou receber ajuda dentro do nosso aplicativo. Ative o acesso à sua câmera nas configurações de privacidade do dispositivo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关闭相机授权将影响本软件的正常使用，请在设备隐私设置中开启。"
          }
        }
      }
    },
    "DisableMicphoneMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie den Zugriff auf Ihr Mikrofon deaktivieren, können Sie in unserer App keine Hilfe geben oder empfangen. Bitte aktivieren Sie den Zugriff auf Ihr Mikrofon in den Datenschutzeinstellungen des Geräts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By disabling access to your microphone, you will not be have video calls help inside our app. Please enable access to your microphone in device's privacy settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al deshabilitar el acceso a su micrófono, no podrá ni recibir ni dar ayuda dentro de nuestra aplicación. Habilite el acceso a su micrófono en la configuración de privacidad del dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En désactivant l'accès à votre microphone, vous ne pourrez pas donner ni recevoir d'aide dans notre application. Veuillez autoriser l'accès à votre microphone dans les paramètres de confidentialité de l'appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disabilitando l'accesso al tuo microfono, non sarai in grado di dare o ricevere aiuto all'interno della nostra app. Abilitare l'accesso al microfono nelle impostazioni sulla privacy del dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "マイクアクセスを無効化すると、Help Lightning アプリ内ヘルプの提供・受領ができなくなります。端末のプライバシー設定でマイクアクセスを許可してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "마이크에 대한 액세스를 비활성화하면 앱 내에서 도움말을 제공하거나받을 수 없습니다. 장치의 개인 정보 설정에서 마이크에 액세스 할 수 있도록 설정하십시오."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao desativar o acesso ao seu microfone, você não poderá dar ou receber ajuda dentro do nosso aplicativo. Ative o acesso ao seu microfone nas configurações de privacidade do dispositivo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关闭麦克风授权将影响本软件的正常使用，请在设备隐私设置中开启。"
          }
        }
      }
    },
