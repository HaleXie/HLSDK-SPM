    "SignUpMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Ihr Unternehmen bereits ein Unternehmenskonto mit {{app_name}} besitzt, wenden Sie sich bitte an den Administrator, um Zugriffsrechte zu beantragen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If your company already has a site account with {{app_name}}, please reach out to your administrator to become a registered user."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si su empresa ya tiene una cuenta en la planta con {{app_name}} , comuníquese con su administrador para convertirse en un usuario registrado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si votre entreprise possède déjà un compte d'entreprise avec {{app_name}}, veuillez contacter votre administrateur pour devenir un utilisateur enregistré."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se la tua azienda ha già un account sul sito con {{app_name}} , contatta il tuo amministratore per diventare un utente registrato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "会社が既に{{app_name}}エンタープライズアカウントを持っている場合は、管理者に連絡して登録ユーザーになってください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "회사에 이미 {{app_name}}, 의 사이트 계정이있는 경우 관리자에게 연락하여 등록사용자가 되도록 신청하십시오."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se a sua empresa já tiver uma conta no site com o {{app_name}} , entre em contato com seu administrador para se tornar um usuário registrado."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果贵公司已是{{app_name}} 企业用户,请联系您公司的帐号管理者, 获取注册用户信息。"
          }
        }
      }
    },
