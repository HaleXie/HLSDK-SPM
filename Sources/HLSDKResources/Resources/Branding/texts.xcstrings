      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch wird dieser Nachrichten-Thread für alle Teilnehmer dauerhaft gelöscht. Bist du dir sicher?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
