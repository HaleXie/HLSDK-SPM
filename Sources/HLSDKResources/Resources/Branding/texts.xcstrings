    "ThirdPartyCallBHD1TopMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie befinden sich derzeit im Face-to-Face-Modus. Wählen Sie für Ihre Rolle Hilfe geben, Hilfe erhalten oder Beobachter aus. Sie werden dann aufgefordert, einem anderen Teilnehmer eine Rolle zuzuweisen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are currently in Face to Face Mode. Select Give Help, Receive Help, Or Observer for your role. You will then be prompted to assign a role to another participant."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actualmente se encuentra en el modo cara a cara. Seleccione Brindar ayuda, Recibir ayuda u Observador para su función. A continuación, se le pedirá que asigne un rol a otro participante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes actuellement en mode Face à Face. Sélectionnez Donner de l'aide, recevoir de l'aide ou un observateur pour votre rôle. Vous serez alors invité à attribuer un rôle à un autre participant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attualmente sei in modalità Faccia a faccia. Seleziona Dai aiuto, Ricevi aiuto o Osservatore per il tuo ruolo. Ti verrà quindi chiesto di assegnare un ruolo a un altro partecipante."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在、対面モードになっています。役割として、[ヘルプする]、[ヘルプされる]、または[オブザーバー]を選択します。次に、別の参加者に役割を割り当てるように求められます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 Face to Face 모드에 있습니다. 역할에 대해 도움 제공, 도움 받기 또는 관찰자를 선택합니다. 그러면 다른 참가자에게 역할을 할당하라는 메시지가 표시됩니다."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está no modo Cara a cara. Selecione Dar ajuda, Receber ajuda ou Observador para sua função. Em seguida, você será solicitado a atribuir uma função a outro participante."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您当前处于面对面模式。选择“提供帮助”，“接收帮助”或“观察者”作为您的角色。然后将提示您将角色分配给其他参与者。"
          }
        }
      }
    },
