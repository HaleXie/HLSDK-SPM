    "NewUserMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben Ihre kostenlose Testversion erfolgreich aktiviert. \\r \\r Mit {{app_name}} können Sie über Ihr Smart-Gerät virtuell mit Kollegen und Kunden interagieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have successfully activated your free trial.\\r\\rWith {{app_name}}, you can virtually interact with colleagues and customers through your smart device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha activado con éxito su prueba gratuita. \\r \\r Con {{app_name}}, puede interactuar virtualmente con compañeros y clientes a través de su dispositivo inteligente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez activé votre essai gratuit avec succès. \\r \\r Avec {{app_name}}, vous pouvez collaborer virtuellement avec vos collègues et clients avec votre téléphone et tablette."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai attivato con successo la tua prova gratuita. \\r \\r Con {{app_name}}, si può  interagire in maniera virtuale con colleghi e clienti attraverso il vostro dispositivo mobile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無料トライアルが正常に有効化されました。 \\r \\r {{app_name}}を使用すると、スマートデバイスを介して同僚や顧客と事実上対話できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "무료 평가판을 성공적으로 활성화했습니다. \\r \\r {{app_name}} , 스마트 장치를 통해 동료 및 고객과 가상으로 상호 작용할 수 있습니다."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
