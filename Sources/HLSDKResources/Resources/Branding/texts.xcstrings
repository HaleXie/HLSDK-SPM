      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Gruppe fehlen erforderliche Informationen zum Starten eines Anrufs. Bitte versuchen Sie es später erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This group is missing required information to start a call. Please try again later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A este grupo le faltan datos obligatorios para iniciar una llamada. Por favor, inténtelo más tarde."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce groupe ne dispose pas des informations requises pour démarrer un appel. Veuillez réessayer plus tard."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A questo gruppo mancano le informazioni richieste per avviare una chiamata. Riprova più tardi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このグループには通話を開始するために必要な情報が不足しています。後でもう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 그룹에는 통화를 시작하는 데 필요한 정보가 없습니다. 나중에 다시 시도해 주세요."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este grupo não tem as informações necessárias para iniciar uma chamada. Por favor, tente novamente mais tarde."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此群组缺少开始通话所需的信息。请稍后重试。"
          }
        }
      }
    },
    "ThisGuestsInviteWillBeRevoked" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
