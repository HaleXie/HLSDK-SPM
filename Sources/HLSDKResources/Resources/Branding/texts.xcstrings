          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ne sera plus pris en charge à partir du 1er octobre 2025. %@ Pour toutes les fonctionnalités de chat, passez à %@ maintenant !"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ non sarà più supportato a partire dal 1° ottobre 2025. %@ Per tutte le funzionalità della chat, passa subito a %@!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@2025年10月1日をもってサポートされなくなります。 %@すべてのチャット機能をご利用になるには、今すぐ%@に切り替えてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@2025년10월1일부터 더 이상 지원되지 않습니다. %@ 모든 채팅 기능을 사용하려면 지금 바로 %@ 로 전환하세요!"
          }
        },
