        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actualmente estás en modo Face to Face. Seleccione Dar o Recibir ayuda para entrar al modo Realidad Combinada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
