    "FirstTimeModeMenuMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie befinden sich derzeit im Face to Face-Modus. Wählen Sie \\\"Give\\\" oder \\\"Receive Help\\\", um in den Modus \\\"Merged Reality\\\" zu wechseln."
          }
        },
        "en" : {
          "stringUnit" : {
