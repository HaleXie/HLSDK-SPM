        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modo de ancho de banda ultrabajo. Pide a otros que compartan contenido. O bien, puede compartir desde el menú a continuación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mode bande passante ultra-faible. Demandez aux autres de partager du contenu. Ou, vous pouvez partager à partir du menu ci-dessous."
