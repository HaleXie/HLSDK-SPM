    "StartUsingMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um {{app_name}} verwenden zu können, müssen Sie Ihrer Liste Kontakte hinzufügen. Tippen Sie auf \\\"Kontakt hinzufügen\\\", um einen registrierten {{app_name}}-Benutzer zu Ihren Kontakten hinzuzufügen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To start using {{app_name}} you need to add contacts to your list. Tap on “Add Contact” to add a registered {{app_name}} User to your Contacts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para comenzar a usar {{app_name}}, debe agregar contactos a su lista. Toque \\\"Agregar contacto\\\" para agregar un usuario registrado de {{app_name}} a sus contactos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour commencer à utiliser {{app_name}}, vous devez ajouter des contacts à votre liste. Appuyez sur «Ajouter un contact» pour ajouter un utilisateur {{app_name}} à vos contacts."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per iniziare a utilizzare {{app_name}} devi aggiungere contatti al tuo elenco. Tocca \\\"Aggiungi contatto\\\" per aggiungere un utente {{app_name}} ai tuoi contatti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}} の使用を開始するには、リストに連絡先を追加する必要があります。登録済みの {{app_name}} を追加するには、[連絡先を追加]をタップします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}} 사용을 시작하려면 목록에 연락처를 추가해야합니다. \\\"연락처 추가\\\"를 눌러 등록 된 {{app_name}} 연락처에 사용자."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para começar a usar o {{app_name}} você precisa adicionar contatos à sua lista. Toque em “Adicionar Contato” para adicionar um {{app_name}} Usuário para seus contatos."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "首先您需要添加联络人到通信簿, 请点击\\\"添加联系人\\\"将已注册的{{app_name}}用户加入您的通信簿。"
          }
        }
      }
    },
