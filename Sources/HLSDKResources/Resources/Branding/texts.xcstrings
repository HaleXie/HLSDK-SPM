    "Tutorial2Message1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A. Wenn Sie sich bei {{app_name}} wird Ihnen Ihre Kontaktliste angezeigt. Tippen Sie auf einen Namen, um einen Anruf einzuleiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A. When you log into {{app_name}}, you’re presented with your Contacts list. Tap on a name to initiate a call."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A. Cuando inicie sesión en {{app_name}}, se le presenta su lista de contactos. Toque un nombre para iniciar una llamada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A. Lorsque vous vous connectez à {{app_name}}, votre liste de contacts vous est présentée. Appuyez sur un nom pour lancer un appel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "R. Quando accedi a {{app_name}}, ti viene presentato l'elenco dei contatti. Tocca un nome per avviare una chiamata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A. {{app_name}}にログインするとき、連絡先リストが表示されます。名前をタップして通話を開始します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A. {{app_name}} 로그인 할 때 , 연락처 목록이 표시됩니다. 전화를 걸려면 이름을 탭하세요."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A. Quando você se loga no {{app_name}} , sua lista de contatos é exibida. Toque em um nome para iniciar uma chamada."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A.登录到{{app_name}} ，系统会向您显示“联系人”列表。点按一个名称以发起呼叫。"
          }
        }
      }
    },
    "Tutorial2Message2" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "B. Oder Sie können jemanden einladen, sich einem Anruf anzuschließen, der kein Kontakt ist. Tippen Sie auf das Einladungssymbol, um eine E-Mail- oder SMS-Einladung zu senden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "B. Or, you can invite someone to join a call who is not a contact. Tap the Invite icon to send an email or text message invitation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "B. O puede invitar a alguien que no sea un contacto a unirse a una llamada. Presiona el ícono Invitar para enviar una invitación por correo electrónico o mensaje de texto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "B. Ou, vous pouvez inviter quelqu'un à rejoindre un appel qui n'est pas un contact. Appuyez sur l'icône Inviter pour envoyer une invitation par courriel ou SMS."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "B. Oppure puoi invitare qualcuno a partecipare a una chiamata che non è un contatto. Tocca l'icona Invita per inviare un'e-mail o un messaggio di testo di invito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "B.または、連絡先にない人を通話に招待することもできます。 [招待]アイコンをタップして、メールまたはテキストメッセージで招待状を送信します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "B. 또는 연락처가 아닌 통화에 다른 사람을 초대 할 수 있습니다. 초대 아이콘을 탭하여 이메일 또는 문자 메시지 초대를 보냅니다."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "B. Ou você pode convidar alguém que não seja um contato para participar de uma chamada. Toque no ícone Convidar para enviar um convite por e-mail ou mensagem de texto."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "B.或者，您可以邀请不是联系人的人加入通话。点击“邀请”图标以发送电子邮件或短信邀请。"
          }
        }
      }
    },
