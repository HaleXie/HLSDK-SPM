        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "팀 연락처로 돌아가려면 상단의 뒤로 화살표를 누르거나 아래의 연락처 아이콘을 누릅니다."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
