        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attualmente sei in modalità Face-To-Face. Seleziona Dai o Ricevi assistenza per accedere alla modalità Merged Reality."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在、対面モードです。ヘルプの提供または受信を選択して、統合現実モードに入ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 대면 모드에 있습니다. 화면 중첩 제공 모드로 들어가려면 도움말 제공 역할 또는 도움을 받는 역할을 선택하십시오."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está atualmente no modo Face a Face. Selecione Dar ou receber ajuda para entrar no modo de Realidade Mista."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您当前在面对面模式，请从菜单中选择对应的模式进入融合现实。"
