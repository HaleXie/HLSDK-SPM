    "WorkboxListPlaceHolderText" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Willkommen bei den Hilfe-Threads! \\n Hier finden Sie die Ihnen zugewiesenen Support-Anrufe und können Anrufe einleiten. Klicken Sie oben auf eine Schaltfläche, um zu beginnen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome to Help Threads! \\n This is where you will find your assigned support calls and where you can initiate calls. Click a button above to get started."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Bienvenido a los hilos de ayuda! \\n Aquí encontrará las llamadas de soporte que le han sido asignadas y podrá iniciarlas. Haga clic en uno de los botones de arriba para comenzar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bienvenue dans les fils d'aide ! \\n C'est ici que vous trouverez les appels d'assistance qui vous sont attribués et où vous pouvez lancer des appels. Cliquez sur un bouton ci-dessus pour commencer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benvenuti in Help Threads! \\n Qui troverete le chiamate di supporto assegnate e dove potrete avviare le chiamate. Cliccate su un pulsante qui sopra per iniziare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ヘルプ スレッドへようこそ! \\nここには、割り当てられたサポート コールが表示され、コールを開始できます。開始するには、上のボタンをクリックしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Help Threads에 오신 것을 환영합니다! \\n 여기에서 할당된 지원 전화를 찾을 수 있으며 전화를 시작할 수 있습니다. 위의 버튼을 클릭하여 시작하세요."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bem-vindo ao Help Threads! \\n É aqui que você encontrará suas chamadas de suporte atribuídas e onde você pode iniciar chamadas. Clique em um botão acima para começar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "欢迎使用帮助主题！ \\n在这里你可以找到分配给你的客服通话，也可以发起通话。点击上方的按钮即可开始。"
          }
        }
      }
    },
