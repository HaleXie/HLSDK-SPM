        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler continuare? Il tuo account e i tuoi dati personali verranno cancellati. Questo non può essere annullato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "続行してもよろしいですか？あなたのアカウントと個人データは消去されます。これは、元に戻すことはできません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계속하시겠습니까? 귀하의 계정과 귀하의 개인 데이터가 지워집니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você tem certeza que quer continuar? Sua conta e seus dados pessoais serão excluídos. Isto não pode ser desfeito."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "确定要继续吗？您的帐户和个人数据将被删除。此操作无法撤消。"
          }
        }
      }
    },
