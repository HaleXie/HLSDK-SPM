        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modalità larghezza di banda ultra ridotta. Chiedi ad altri di condividere contenuti. Oppure puoi condividere dal menu sottostante."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "超低帯域幅モード。他の人にコンテンツを共有してもらいます。または、下のメニューから共有することもできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "초저대역폭 모드. 다른 사람에게 콘텐츠를 공유하도록 요청하세요. 또는 아래 메뉴에서 공유할 수 있습니다."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modo de largura de banda ultrabaixa. Peça a outras pessoas para compartilhar conteúdo. Ou você pode compartilhar no menu abaixo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "超低带宽模式。请其他人分享内容。或者，您可以从下面的菜单中分享。"
