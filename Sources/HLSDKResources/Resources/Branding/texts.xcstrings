    "ExpertLicenseDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kann auf Basisfunktionen in {{app_name}} zugreifen, Links zu \\\"Mein Hilfebereich\\\" senden, persönliche Benutzer einladen und Mitglied einer Experten- / Bereitschaftsgruppe sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Can access base features in {{app_name}}, send My Help Space links, invite Personal users, and may be a member of an Expert/On-call Group."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puede acceder a las funciones básicas en {{app_name}}, enviar enlaces de Mi Help Space, invitar a usuarios personales y puede ser miembro de un grupo de expertos / de guardia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peut accéder aux fonctionnalités de base de {{app_name}}, envoyer des liens une invitation pour inviter un contact personnel our groupe d'experts / d'astreinte."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Può accedere alle funzioni di base in {{app_name}}, inviare collegamenti Area Assistenza Personale, invitare utenti personali e può essere membro di un gruppo di esperti / su chiamata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}}の基本機能にアクセスしたり、My Help Spaceリンクを送信したり、個人ユーザーを招待したり、エキスパート/オンコールグループのメンバーになることができます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "{{app_name}} 기본 기능에 액세스하고, My Help Space 링크를 보내고, 개인 사용자를 초대하고, Expert / On-Call 그룹의 구성원이 될 수 있습니다."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pode acessar recursos básicos no {{app_name}}, envie links do Meu Espaço de Ajuda, convide usuários pessoais e pode ser membro de um Grupo de Especialistas / de Serviço."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有权限使用{{app_name}}的基本功能，发送我的帮助空间的链接，邀请个人客户，并且也可是专家组的成员。"
          }
        }
      }
    },
